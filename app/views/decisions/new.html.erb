<%= render "shared/guide_modal" %>

<% if current_user && !current_user.first_login_done? %>
  <script>
    document.addEventListener("turbo:load", function () {
      const el = document.getElementById("guideModal")
      if (!el) return
      const modal = new bootstrap.Modal(el)
      modal.show()
    })
  </script>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">決断作成</h1>

  <button
    class="btn btn-outline-info btn-sm"
    data-bs-toggle="modal"
    data-bs-target="#guideModal">
    ガイド
  </button>
</div>

<% if @decision.errors.any? %>
  <div class="alert alert-danger">
    <h5 class="mb-2">
      <%= @decision.errors.count %>件のエラーがあります
    </h5>
    <ul class="mb-0">
      <% @decision.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @decision,
      local: true,
      data: {
        controller: "decision-preview loading",
        action: "submit->loading#submit"
      } do |f| %>

  <div class="mb-3">
    <%= f.label :title, "タイトル", class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :recorded_on, "日付", class: "form-label" %>
    <%= f.date_field :recorded_on, class: "form-control" %>
  </div>

  <div class="mb-4"
     data-controller="category-suggestions"
     data-categories="<%= Category.all.to_json %>">

  <%= f.label :category_id, "カテゴリ", class: "form-label" %>

  <%= text_field_tag :category_name,
        @decision.category&.name,
        list: "category-list",
        class: "form-control",
        placeholder: "カテゴリを入力または選択",
        data: {
          category_suggestions_target: "input",
          action: "change->category-suggestions#select"
        } %>

  <datalist id="category-list">
    <% Category.all.each do |category| %>
      <option value="<%= category.name %>">
    <% end %>
  </datalist>

  <%= f.hidden_field :category_id,
        value: @decision.category_id,
        data: {
          category_suggestions_target: "hidden"
        } %>

</div>



  <hr>

  <h5 class="mb-3">選択肢</h5>

  <% @decision.options.each_with_index do |option, index| %>
  <div class="mb-2 option-item">

    <%= text_field_tag "decision[options_attributes][#{index}][content]",
          option.content,
          class: "form-control option-input",
          data: {
            decision_preview_target: "input",
            action: "input->decision-preview#refresh"
          } %>

    <%= hidden_field_tag "decision[options_attributes][#{index}][id]", option.id %>

    <%= hidden_field_tag "decision[options_attributes][#{index}][_destroy]", "0", class: "destroy-flag" %>

  </div>
<% end %>

  <hr>

  <h5 class="mb-3">最終決断</h5>

<div data-decision-preview-target="final"></div>

<div class="mt-3">
  <strong>選択中：</strong>
  <span data-decision-preview-target="preview" class="choicecolor">未選択</span>
</div>

  <hr>

  <div class="mb-4">
    <%= f.label :reason, "決断理由", class: "form-label" %>
    <%= f.text_area :reason, class: "form-control", rows: 4 %>
  </div>

  <hr>

  <h5 class="mb-3">感情</h5>

  <% EmotionType.all.each do |emotion| %>
    <div class="form-check mb-2">
      <%= check_box_tag "decision[emotion_type_ids][]",
            emotion.id,
            @decision.emotion_type_ids.include?(emotion.id),
            id: "emotion_#{emotion.id}",
            class: "form-check-input" %>

      <%= label_tag "emotion_#{emotion.id}",
            emotion.name,
            class: "form-check-label" %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= f.submit "作成する",
          class: "btn btn-primary w-100",
          data: { loading_text: "作成中..." } %>
  </div>

<% end %>

<%= link_to "戻る",
      decisions_path,
      class: "btn btn-secondary w-100 mt-2" %>
