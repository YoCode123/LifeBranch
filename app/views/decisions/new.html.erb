<%= render "shared/guide_modal" %>

<% if current_user && !current_user.first_login_done? %>
  <script>
    document.addEventListener("turbo:load", function () {
      const el = document.getElementById("guideModal")
      if (!el) return

      const modal = new bootstrap.Modal(el)
      modal.show()
    })
  </script>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">

  <h1 class="mb-0">決断作成</h1>

  <% if controller_name == "decisions" && action_name == "new" %>
    <button
      class="btn btn-outline-info btn-sm"
      data-bs-toggle="modal"
      data-bs-target="#guideModal">
      ガイド
    </button>
  <% end %>

</div>

<% if @decision.errors.any? %>

  <div class="alert alert-danger">

    <h5 class="mb-2">
      <%= @decision.errors.count %>件のエラーがあります
    </h5>

    <ul class="mb-0">
      <% @decision.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>

  </div>

<% end %>

<%= form_with model: @decision,
      local: true,
      data: { controller: "decision-form" } do |f| %>

  <!-- タイトル -->
  <div class="mb-3">

    <%= f.label :title,
          "タイトル",
          class: "form-label" %>

    <%= f.text_field :title,
          class: "form-control",
          placeholder: "例: 転職するか迷っている" %>

  </div>

  <!-- 日付 -->
  <div class="mb-3">

    <%= f.label :recorded_on,
          "日付",
          class: "form-label" %>

    <%= f.date_field :recorded_on,
          class: "form-control" %>

  </div>

  <!-- カテゴリ -->
  <div class="mb-4">

    <%= f.label :category_id,
          "カテゴリ",
          class: "form-label" %>

    <%= f.collection_select :category_id,
          Category.all,
          :id,
          :name,
          { prompt: "選択してください" },
          class: "form-select" %>

  </div>

  <hr>

  <!-- 選択肢 -->
  <h5 class="mb-3">選択肢</h5>

  <div
    id="options-container"
    data-decision-form-target="container">

    <% @decision.options.each_with_index do |option, index| %>

      <div class="mb-2 option-item">

        <%= text_field_tag "decision[options_attributes][#{index}][content]",
              option.content,
              class: "form-control option-input",
              placeholder: "選択肢#{index + 1}",
              data: {
                action: "input->decision-form#refresh"
              } %>

      </div>

    <% end %>

  </div>

  <hr>

  <!-- 最終決断 -->
  <h5 class="mb-3">最終決断</h5>

  <div
    data-decision-form-target="final">

    <% selected_index =
         params.dig(:decision, :selected_option_index) %>

    <% @decision.options.each_with_index do |option, index| %>

      <div class="form-check mb-2">

        <%= radio_button_tag "decision[selected_option_index]",
              index,
              selected_index.to_i == index,
              id: "option_#{index}",
              class: "form-check-input decision-radio",
              data: {
                action: "change->decision-form#refresh"
              } %>

        <%= label_tag "option_#{index}",
              (option.content.presence || "選択肢#{index + 1}"),
              class: "form-check-label",
              id: "option-label-#{index}" %>

      </div>

    <% end %>

  </div>

  <!-- 選択中 -->
  <div class="mt-3">

    <strong>選択中：</strong>

    <span
      id="selected-option-preview"
      class="text-success">

      <% if selected_index.present? %>

        <%= @decision
              .options[selected_index.to_i]
              &.content
              .presence || "未選択" %>

      <% else %>

        未選択

      <% end %>

    </span>

  </div>

  <hr>

  <!-- 理由 -->
  <div class="mb-4">

    <%= f.label :reason,
          "決断理由",
          class: "form-label" %>

    <%= f.text_area :reason,
          class: "form-control",
          rows: 4,
          placeholder: "なぜこの決断をしたかを書いてみましょう" %>

  </div>

  <hr>

  <!-- 感情 -->
  <h5 class="mb-3">感情</h5>

  <% selected_emotions =
       Array(params.dig(:decision, :emotion_type_ids)) %>

  <% @emotion_types.each do |emotion| %>

    <div class="form-check mb-2">

      <%= check_box_tag "decision[emotion_type_ids][]",
            emotion.id,
            selected_emotions.include?(emotion.id.to_s),
            id: "emotion_#{emotion.id}",
            class: "form-check-input" %>

      <%= label_tag "emotion_#{emotion.id}",
            emotion.name,
            class: "form-check-label" %>

    </div>

  <% end %>

  <!-- 作成 -->
  <div class="mt-4">

    <%= f.submit "作成する",
          class: "btn btn-primary w-100" %>

  </div>

<% end %>

<!-- 戻る -->
<%= link_to "戻る",
      decisions_path,
      class: "btn btn-secondary w-100 mt-2" %>
