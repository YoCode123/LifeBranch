<h1 class="mb-4">決断詳細</h1>

<div class="card mb-4">

  <div class="card-body">

    <h2 class="card-title">
      <%= @decision.title %>
    </h2>

    <% date =
        @decision.recorded_on.presence ||
        @decision.created_at.to_date %>

    <p class="card-text mb-2">

      日付：

      <%= date == Date.today ?
            "今日" :
            date.strftime("%Y年%m月%d日") %>

    </p>

    <p class="card-text">

      カテゴリ:
      <%= @decision.category&.name || "未設定" %>

    </p>

  </div>

</div>

<hr>

<h3 class="mb-3">感情</h3>

<% if @decision.decision_emotions.any? %>

  <div class="mb-3">

    <% @decision.decision_emotions.each do |de| %>

      <span class="badge bg-primary me-1 mb-1">
        <%= de.emotion_type&.name || "不明" %>
      </span>

    <% end %>

  </div>

<% else %>

  <p class="text-muted">
    感情はまだ記録されていません
  </p>

<% end %>

<hr>

<h3 class="mb-3">選択肢</h3>

<ul class="list-group mb-4">

  <% @decision.options.each do |option| %>

    <li class="
      list-group-item
      d-flex
      justify-content-between
      align-items-center
      <%= 'list-group-item-success' if @decision.selected_option_id == option.id %>
    ">

      <div>

        <%= option.content %>

        <% if @decision.selected_option_id == option.id %>

          <span class="badge bg-success ms-2">
            選択中
          </span>

        <% end %>

      </div>

    </li>

  <% end %>

</ul>

<hr>

<h5 class="mb-3">最終決断</h5>

<% selected_option =
     @decision.options.find_by(
       id: @decision.selected_option_id
     ) %>

<% if selected_option.present? %>

  <div class="alert alert-success">

    <strong>選択済み：</strong>
    <%= selected_option.content %>

  </div>

<% else %>

  <div class="alert alert-secondary">
    未選択
  </div>

<% end %>

<hr>

<h3 class="mb-3">決断理由</h3>

<% if @decision.reason.present? %>

  <div class="alert alert-secondary">

    <%= @decision.reason %>

  </div>

<% else %>

  <p class="text-muted">
    理由はまだ記録されていません
  </p>

<% end %>

<hr>

<div class="d-flex gap-2">

  <%= link_to "編集",
        edit_decision_path(@decision),
        class: "btn btn-warning" %>

</div>

<%= link_to "一覧に戻る",
      decisions_path,
      class: "btn btn-secondary w-100 mt-3" %>
